-- Tabloları oluştur
CREATE TABLE Shipments (ShipmentID INTEGER PRIMARY KEY, MedicineID TEXT, RouteID TEXT, DepartureDate DATE);
CREATE TABLE ColdChainLogs (LogID INTEGER PRIMARY KEY, ShipmentID INTEGER, Temperature REAL, Timestamp TEXT);
CREATE TABLE Inventory_Status (ShipmentID INTEGER PRIMARY KEY, Status TEXT);

