INSERT INTO ColdChainLogs VALUES (1, 101, 4, '10:00'), (2, 102, 9, '11:00'), (3, 103, 5, '12:00');
INSERT INTO Inventory_Status VALUES (101, 'Delivered'), (102, 'Returned for Disposal'), (103, 'Delivered');

-- Analiz sorgusunu çalıştır
SELECT s.ShipmentID, s.MedicineID, c.Temperature, i.Status
FROM Shipments s
JOIN ColdChainLogs c ON s.ShipmentID = c.ShipmentID
JOIN Inventory_Status i ON s.ShipmentID = i.ShipmentID
WHERE c.Temperature > 8;
